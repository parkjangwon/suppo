{
  "name": "crinity-helpdesk",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:all",
    "dev:admin": "pnpm --filter=@crinity/admin dev",
    "dev:public": "pnpm --filter=@crinity/public dev",
    "dev:all": "pnpm -r --parallel --filter=@crinity/public --filter=@crinity/admin dev",
    "build:admin": "pnpm --filter=@crinity/admin build",
    "build:public": "pnpm --filter=@crinity/public build",
    "build:all": "pnpm build:public && pnpm build:admin",
    "start:all": "pnpm -r --parallel --filter=@crinity/public --filter=@crinity/admin start",
    "lint": "pnpm -r lint",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.53.2",
    "@prisma/client": "^6.7.0",
    "@vitejs/plugin-react": "^4.5.0",
    "dotenv": "^17.3.1",
    "jsdom": "^25.0.1",
    "next": "^15.3.1",
    "playwright": "^1.53.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.33.0"
}
