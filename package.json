{
  "name": "suppo",
  "private": true,
  "scripts": {
    "postinstall": "pnpm --filter=@suppo/db generate",
    "dev": "pnpm dev:all",
    "dev:admin": "pnpm --filter=@suppo/admin dev",
    "dev:public": "pnpm --filter=@suppo/public dev",
    "dev:all": "pnpm -r --parallel --filter=@suppo/public --filter=@suppo/admin dev",
    "build:admin": "pnpm --filter=@suppo/admin build",
    "build:public": "pnpm --filter=@suppo/public build",
    "build:all": "pnpm build:public && pnpm build:admin",
    "start:all": "pnpm -r --parallel --filter=@suppo/public --filter=@suppo/admin start",
    "lint": "pnpm -r lint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "ops:auth-audit": "node scripts/audit-api-auth.mjs",
    "ops:backup-drill": "node scripts/ops-backup-restore-drill.mjs",
    "ops:validate-env": "tsx scripts/validate-production-env.ts",
    "ops:smoke": "node scripts/ops-smoke-test.mjs"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.53.2",
    "@prisma/client": "^6.19.3",
    "@vitejs/plugin-react": "^5.2.0",
    "dotenv": "^17.3.1",
    "jsdom": "^25.0.1",
    "jszip": "^3.10.1",
    "next": "^15.5.15",
    "playwright": "^1.53.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "defu": "^6.1.5",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
