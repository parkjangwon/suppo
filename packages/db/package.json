{
  "name": "@suppo/db",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./raw": "./src/raw.ts"
  },
  "scripts": {
    "generate": "prisma generate --schema=./prisma/schema.prisma",
    "bootstrap": "set -a && . ../../.env && set +a && tsx prisma/bootstrap.ts",
    "migrate:dev": "set -a && . ../../.env && set +a && prisma migrate dev --schema=./prisma/schema.prisma",
    "migrate:deploy": "set -a && . ../../.env && set +a && prisma migrate deploy --schema=./prisma/schema.prisma",
    "seed": "set -a && . ../../.env && set +a && tsx prisma/seed.ts",
    "studio": "set -a && . ../../.env && set +a && prisma studio --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
