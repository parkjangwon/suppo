# 외부에서 접속하는 최종 URL (리버스 프록시 뒤라면 프록시 URL)
PUBLIC_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# 포트 바인딩
# BIND_IP: 127.0.0.1 = 로컬 전용 / 0.0.0.0 = 외부 노출
BIND_IP=127.0.0.1
PUBLIC_PORT=3000
ADMIN_PORT=3001

# 인증 시크릿 — 비워두면 docker compose up 시 자동 생성됨
# 직접 지정하려면 값을 채울 것 (openssl rand -base64 32)
AUTH_SECRET=
TICKET_ACCESS_SECRET=
GIT_TOKEN_ENCRYPTION_KEY=

# 초기 관리자 계정
INITIAL_ADMIN_EMAIL=admin@suppo.io
# 비워두면 admin1234 기본값이 사용됨
INITIAL_ADMIN_PASSWORD=

# 초기 데이터
# AUTO_BOOTSTRAP: if-empty(기본) | always | never
AUTO_BOOTSTRAP=if-empty
# SEED_PROFILE: demo(기본) | none
SEED_PROFILE=demo

# LibSQL 인증 토큰 (선택)
DATABASE_AUTH_TOKEN=
