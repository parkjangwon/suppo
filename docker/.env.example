# =============================================================================
# Suppo — Docker Compose 환경변수 설정
# 이 파일을 복사한 뒤 .env 로 저장하고 값을 채워주세요.
#   cp docker/.env.example docker/.env
# =============================================================================


# -----------------------------------------------------------------------------
# [필수] 접속 URL
# 리버스 프록시(nginx, Caddy 등) 뒤에 두는 경우 프록시의 외부 URL을 입력하세요.
# -----------------------------------------------------------------------------
PUBLIC_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# 앱 기본 URL (이메일 링크 생성 등에 사용, PUBLIC_URL과 동일하게 설정)
APP_BASE_URL=http://localhost:3000

# 파일 업로드 디렉토리 (컨테이너 내부 경로, 볼륨 마운트 경로와 일치해야 함)
UPLOAD_DIR=/app/uploads

# 포트 바인딩
# BIND_IP: 127.0.0.1 = 로컬 전용 (리버스 프록시 권장) / 0.0.0.0 = 외부 직접 노출
BIND_IP=127.0.0.1
PUBLIC_PORT=3000
ADMIN_PORT=3001


# -----------------------------------------------------------------------------
# [필수] 시크릿 키
# 비워두면 docker compose up 시 자동으로 생성됩니다.
# 직접 지정하려면: openssl rand -base64 32
# 한 번 설정한 뒤에는 절대 변경하지 마세요 (세션/토큰이 무효화됩니다).
# -----------------------------------------------------------------------------
AUTH_SECRET=
TICKET_ACCESS_SECRET=
GIT_TOKEN_ENCRYPTION_KEY=


# -----------------------------------------------------------------------------
# [필수] 초기 관리자 계정
# -----------------------------------------------------------------------------
INITIAL_ADMIN_EMAIL=admin@suppo.io
# 비워두면 'admin1234' 기본값이 사용됩니다. 반드시 변경하세요.
INITIAL_ADMIN_PASSWORD=


# -----------------------------------------------------------------------------
# [필수] 초기 데이터 시딩
# AUTO_BOOTSTRAP: if-empty(기본, 최초 1회) | always | never
# SEED_PROFILE:   demo(기본, 샘플 데이터 포함) | none
# -----------------------------------------------------------------------------
AUTO_BOOTSTRAP=if-empty
SEED_PROFILE=demo


# -----------------------------------------------------------------------------
# [선택] LibSQL 인증 토큰
# Turso 원격 DB를 사용하는 경우에만 필요합니다.
# 내장 sqld 컨테이너를 사용하는 경우 비워두세요.
# -----------------------------------------------------------------------------
DATABASE_AUTH_TOKEN=


# -----------------------------------------------------------------------------
# [선택] CAPTCHA — Cloudflare Turnstile
# 공개 문의 폼의 스팸 방지용입니다.
# https://dash.cloudflare.com 에서 사이트 키와 시크릿 키를 발급받으세요.
# 미설정 시 개발 환경에서는 우회, 운영 환경에서는 CAPTCHA 검증이 비활성화됩니다.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=


# -----------------------------------------------------------------------------
# [선택] OAuth 소셜 로그인 (관리자 패널)
# 설정된 항목만 로그인 화면에 표시됩니다.
# -----------------------------------------------------------------------------

# Google OAuth
# https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth
# https://github.com/settings/developers → OAuth Apps
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=


# -----------------------------------------------------------------------------
# [선택] SAML SSO (BoxyHQ)
# 엔터프라이즈 SSO 연동 시 사용합니다.
# https://boxyhq.com/docs/jackson/deploy 참고
# -----------------------------------------------------------------------------
AUTH_BOXYHQ_SAML_ID=
AUTH_BOXYHQ_SAML_SECRET=
AUTH_BOXYHQ_SAML_ISSUER=


# -----------------------------------------------------------------------------
# [선택] 이메일 발송 — 아래 중 하나를 설정하세요
# 미설정 시 이메일 발송 기능이 비활성화됩니다.
# -----------------------------------------------------------------------------

# Resend (권장: https://resend.com)
RESEND_API_KEY=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# TLS 사용 여부 (465 포트는 true, 587은 false)
SMTP_SECURE=false

# 발신 도메인 (이메일 주소에 사용: noreply@<EMAIL_DOMAIN>)
EMAIL_DOMAIN=


# -----------------------------------------------------------------------------
# [선택] 수신 이메일 웹훅 (이메일 → 티켓 자동 생성)
# 이메일 수신 서비스(Postmark, Mailgun 등)에서 웹훅을 전송할 때 사용합니다.
# -----------------------------------------------------------------------------
EMAIL_WEBHOOK_SECRET=
EMAIL_WEBHOOK_API_KEY=


# -----------------------------------------------------------------------------
# [선택] Git 연동
# -----------------------------------------------------------------------------

# GitHub 웹훅 시크릿 (GitHub → 설정 → Webhooks에서 설정한 값과 동일해야 합니다)
GITHUB_WEBHOOK_SECRET=

# GitLab API URL (기본값: https://gitlab.com/api/v4, 셀프호스팅 시 변경)
GITLAB_API_BASE=


# -----------------------------------------------------------------------------
# [선택] 모니터링 / 에러 추적
# -----------------------------------------------------------------------------

# Sentry (https://sentry.io)
SENTRY_DSN=

# Redis (성능 캐싱용, 미설정 시 인메모리 캐시 사용)
REDIS_URL=


# -----------------------------------------------------------------------------
# [선택] SEO
# Google Search Console 소유권 확인 메타 태그 값
# -----------------------------------------------------------------------------
GOOGLE_SITE_VERIFICATION=
