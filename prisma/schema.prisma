generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum AgentRole {
  ADMIN
  AGENT
}

enum AuthorType {
  CUSTOMER
  AGENT
}

enum ActivityAction {
  CREATED
  ASSIGNED
  STATUS_CHANGED
  TRANSFERRED
  PRIORITY_CHANGED
}

enum GitProvider {
  GITHUB
  GITLAB
  CODECOMMIT
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
  GITHUB
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  FAILED
}

model Ticket {
  id            String         @id @default(cuid())
  ticketNumber  String         @unique
  customerName  String
  customerEmail String
  customerPhone String?
  subject       String
  description   String
  categoryId    String
  priority      TicketPriority
  status        TicketStatus   @default(OPEN)
  assigneeId    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  resolvedAt    DateTime?
  closedAt      DateTime?

  category  Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  assignee  Agent?          @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments  Comment[]
  attachments Attachment[]
  gitLinks  GitLink[]
  transfers TicketTransfer[]
  activities TicketActivity[]

  @@index([categoryId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
}

model Agent {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  role           AgentRole    @default(AGENT)
  isActive       Boolean      @default(true)
  maxTickets     Int          @default(10)
  avatarUrl      String?
  authProvider   AuthProvider @default(CREDENTIALS)
  passwordHash   String?
  lastAssignedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  assignedTickets   Ticket[]           @relation("TicketAssignee")
  categories        AgentCategory[]
  authoredComments  Comment[]          @relation("CommentAuthor")
  createdTemplates  ResponseTemplate[] @relation("TemplateCreator")
  activityEntries   TicketActivity[]   @relation("ActivityActor")
  transfersFrom     TicketTransfer[]   @relation("TransferFromAgent")
  transfersTo       TicketTransfer[]   @relation("TransferToAgent")

  @@index([isActive])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets           Ticket[]
  specializedAgents AgentCategory[]
  templates         ResponseTemplate[]

  @@index([sortOrder])
}

model AgentCategory {
  agentId    String
  categoryId String
  createdAt  DateTime @default(now())

  agent    Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([agentId, categoryId])
  @@index([categoryId])
}

model Comment {
  id          String     @id @default(cuid())
  ticketId    String
  authorType  AuthorType
  authorId    String?
  authorName  String
  authorEmail String
  content     String
  isInternal  Boolean    @default(false)
  createdAt   DateTime   @default(now())

  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author      Agent?       @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  attachments Attachment[]

  @@index([ticketId])
  @@index([authorId])
}

model Attachment {
  id         String   @id @default(cuid())
  ticketId   String
  commentId  String?
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  uploadedBy String
  createdAt  DateTime @default(now())

  ticket  Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([commentId])
}

model GitLink {
  id           String      @id @default(cuid())
  ticketId     String
  provider     GitProvider
  repoFullName String
  issueNumber  Int
  issueUrl     String
  createdAt    DateTime    @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@unique([provider, repoFullName, issueNumber])
}

model TicketTransfer {
  id          String   @id @default(cuid())
  ticketId    String
  fromAgentId String
  toAgentId   String
  reason      String?
  createdAt   DateTime @default(now())

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromAgent Agent  @relation("TransferFromAgent", fields: [fromAgentId], references: [id], onDelete: Restrict)
  toAgent   Agent  @relation("TransferToAgent", fields: [toAgentId], references: [id], onDelete: Restrict)

  @@index([ticketId])
  @@index([fromAgentId])
  @@index([toAgentId])
}

model ResponseTemplate {
  id          String   @id @default(cuid())
  title       String
  content     String
  categoryId  String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category  Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy Agent     @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([categoryId])
  @@index([createdById])
}

model TicketActivity {
  id        String         @id @default(cuid())
  ticketId  String
  actorType AuthorType
  actorId   String?
  action    ActivityAction
  oldValue  String?
  newValue  String?
  createdAt DateTime       @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  Agent? @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([actorId])
  @@index([action])
}

model GitProviderCredential {
  id             String      @id @default(cuid())
  provider       GitProvider @unique
  encryptedToken String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model NotificationSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailDelivery {
  id           String              @id @default(cuid())
  to           String
  subject      String
  body         String
  status       EmailDeliveryStatus @default(PENDING)
  attemptCount Int                 @default(0)
  nextRetryAt  DateTime?
  lastError    String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([status, nextRetryAt])
}
