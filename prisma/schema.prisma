generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum AgentRole {
  ADMIN
  AGENT
}

enum AuthorType {
  CUSTOMER
  AGENT
  SYSTEM
}

enum ActivityAction {
  CREATED
  ASSIGNED
  STATUS_CHANGED
  TRANSFERRED
  PRIORITY_CHANGED
  MERGED
  UNMERGED
}

enum GitProvider {
  GITHUB
  GITLAB
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
  GITHUB
  SAML
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum SLATarget {
  FIRST_RESPONSE
  RESOLUTION
}

enum SLAClockStatus {
  RUNNING
  PAUSED
  STOPPED
}

enum RequestTypeChannel {
  WEB
  EMAIL
  API
  IN_APP
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
}

enum GitEventType {
  COMMIT_PUSHED
  BRANCH_CREATED
  PR_OPENED
  PR_MERGED
  PR_CLOSED
  ISSUE_LINKED
}

model Ticket {
  id                   String             @id @default(cuid())
  ticketNumber         String             @unique
  customerId           String?
  customerName         String
  customerEmail        String
  customerPhone        String?
  customerOrganization String?
  subject              String
  description          String
  categoryId           String?
  priority             TicketPriority
  status               TicketStatus       @default(OPEN)
  assigneeId           String?
  requestTypeId        String?
  teamId               String?
  source               RequestTypeChannel @default(WEB)
  environment          String?
  serviceModule        String?
  firstResponseAt      DateTime?
  resolvedAt           DateTime?
  closedAt             DateTime?
  reopenedCount        Int                @default(0)
  tags                 String?            @default("[]")
  searchVector         String?
  summary              String?
  summaryUpdatedAt     DateTime?
  mergedIntoId         String?
  mergedFromTickets    TicketMerge[]      @relation("TicketTarget")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  createdBy            String?
  updatedBy            String?

  category          Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  assignee          Agent?                 @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  team              Team?                  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  requestType       RequestType?           @relation(fields: [requestTypeId], references: [id], onDelete: SetNull)
  customer          Customer?              @relation("CustomerTickets", fields: [customerId], references: [id], onDelete: SetNull)
  comments          Comment[]
  attachments       Attachment[]
  gitLinks          GitLink[]
  gitEvents         GitEvent[]
  transfers         TicketTransfer[]
  activities        TicketActivity[]
  slaClocks         SLAClock[]
  customFieldValues CustomFieldValue[]
  satisfactions     CustomerSatisfaction[]
  timeEntries       TimeEntry[]
  mergedFrom        TicketMerge[]          @relation("TicketSource")
  presences         TicketPresence[]
  commentLock       TicketCommentLock?

  @@index([categoryId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@index([teamId])
  @@index([requestTypeId])
  @@index([customerId])
  @@index([createdAt])
  @@index([searchVector])
  @@index([mergedIntoId])
}

model Agent {
  id                String       @id @default(cuid())
  name              String
  email             String       @unique
  phone             String?
  role              AgentRole    @default(AGENT)
  isActive          Boolean      @default(true)
  maxTickets        Int          @default(10)
  avatarUrl         String?
  authProvider      AuthProvider @default(CREDENTIALS)
  passwordHash      String?
  passwordChangedAt DateTime?
  isInitialPassword Boolean      @default(false)
  lastAssignedAt    DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  assignedTickets  Ticket[]           @relation("TicketAssignee")
  categories       AgentCategory[]
  authoredComments Comment[]          @relation("CommentAuthor")
  createdTemplates ResponseTemplate[] @relation("TemplateCreator")
  activityEntries  TicketActivity[]   @relation("ActivityActor")
  transfersFrom    TicketTransfer[]   @relation("TransferFromAgent")
  transfersTo      TicketTransfer[]   @relation("TransferToAgent")
  teamMemberships  TeamMember[]
  savedFilters           SavedFilter[]      @relation("FilterCreator")
  absences               AgentAbsence[]     @relation("AgentAbsenceToAgent")
  createdAbsences        AgentAbsence[]     @relation("AbsenceCreator")
  timeEntries            TimeEntry[]        @relation("TimeEntries")
  automationRules        AutomationRule[]   @relation("AutomationCreator")
  authoredKnowledge      KnowledgeArticle[] @relation("KnowledgeArticleAuthor")
  editedKnowledge        KnowledgeArticle[] @relation("KnowledgeArticleLastEditor")
  ticketPresences        TicketPresence[]
  commentLocks           TicketCommentLock[]

  @@index([isActive])
}

model AgentAbsence {
  id          String      @id @default(cuid())
  agentId     String
  title       String
  description String?
  type        AbsenceType @default(VACATION)
  startDate   DateTime
  endDate     DateTime
  isAllDay    Boolean     @default(true)
  createdById String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  agent     Agent @relation("AgentAbsenceToAgent", fields: [agentId], references: [id], onDelete: Cascade)
  createdBy Agent @relation("AbsenceCreator", fields: [createdById], references: [id])

  @@index([agentId])
  @@index([startDate, endDate])
  @@index([agentId, startDate, endDate])
}

enum AbsenceType {
  VACATION
  SICK_LEAVE
  BUSINESS_TRIP
  REMOTE_WORK
  TRAINING
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  ASSIGN
  TRANSFER
  STATUS_CHANGE
  PRIORITY_CHANGE
  SETTINGS_CHANGE
  PASSWORD_RESET
  ACTIVATE
  DEACTIVATE
  USE
}

model AuditLog {
  id           String      @id @default(cuid())
  actorId      String
  actorType    AuthorType
  actorName    String
  actorEmail   String
  action       AuditAction
  resourceType String
  resourceId   String?
  description  String
  oldValue     Json?
  newValue     Json?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())

  @@index([actorId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
  @@index([actorId, createdAt])
}

model Customer {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  phone        String?
  memo         String?
  analysis     String?
  analyzedAt   DateTime?
  ticketCount  Int       @default(0)
  lastTicketAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tickets Ticket[] @relation("CustomerTickets")

  @@index([email])
  @@index([lastTicketAt])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets           Ticket[]
  specializedAgents AgentCategory[]
  templates         ResponseTemplate[]
  requestType       RequestType? // One-to-one relation with RequestType

  @@index([sortOrder])
}

model AgentCategory {
  agentId    String
  categoryId String
  createdAt  DateTime @default(now())

  agent    Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([agentId, categoryId])
  @@index([categoryId])
}

model Comment {
  id          String     @id @default(cuid())
  ticketId    String
  authorType  AuthorType
  authorId    String?
  authorName  String
  authorEmail String
  content     String
  isInternal  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author      Agent?       @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  attachments Attachment[]

  @@index([ticketId])
  @@index([authorId])
}

model Attachment {
  id         String   @id @default(cuid())
  ticketId   String
  commentId  String?
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  uploadedBy String
  createdAt  DateTime @default(now())

  ticket  Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([commentId])
}

model GitLink {
  id           String      @id @default(cuid())
  ticketId     String
  provider     GitProvider
  repoFullName String
  issueNumber  Int
  issueUrl     String
  createdAt    DateTime    @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([provider, repoFullName, issueNumber])
  @@index([ticketId])
}

model TicketTransfer {
  id          String   @id @default(cuid())
  ticketId    String
  fromAgentId String
  toAgentId   String
  reason      String?
  createdAt   DateTime @default(now())

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromAgent Agent  @relation("TransferFromAgent", fields: [fromAgentId], references: [id], onDelete: Restrict)
  toAgent   Agent  @relation("TransferToAgent", fields: [toAgentId], references: [id], onDelete: Restrict)

  @@index([ticketId])
  @@index([fromAgentId])
  @@index([toAgentId])
}

model ResponseTemplate {
  id            String   @id @default(cuid())
  title         String
  content       String
  variables     Json? // 사용 가능한 변수 목록 [{"name": "customer.name", "description": "고객 이름"}]
  categoryId    String?
  requestTypeId String? // 추천 대상 문의 유형
  createdById   String
  isShared      Boolean  @default(true)
  isRecommended Boolean  @default(false) // 추천 여부
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  requestType RequestType? @relation(fields: [requestTypeId], references: [id], onDelete: SetNull)
  createdBy   Agent        @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([categoryId])
  @@index([requestTypeId])
  @@index([createdById])
  @@index([sortOrder])
}

model TicketActivity {
  id        String         @id @default(cuid())
  ticketId  String
  actorType AuthorType
  actorId   String?
  action    ActivityAction
  oldValue  String?
  newValue  String?
  createdAt DateTime       @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  Agent? @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([actorId])
  @@index([action])
}

model GitProviderCredential {
  id             String      @id @default(cuid())
  provider       GitProvider @unique
  encryptedToken String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model NotificationSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailDelivery {
  id           String              @id @default(cuid())
  to           String
  subject      String
  body         String
  status       EmailDeliveryStatus @default(PENDING)
  attemptCount Int                 @default(0)
  nextRetryAt  DateTime?
  lastError    String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([status, nextRetryAt])
}

// SAML SSO Provider Configuration
model SAMLProvider {
  id       String  @id @default(cuid())
  name     String // 회사명 (예: "ACME Corp")
  domain   String  @unique // 이메일 도메인 (예: "acme.com")
  isActive Boolean @default(true)

  // IdP Configuration
  idpEntityId    String // Identity Provider Entity ID
  idpSsoUrl      String // SSO URL
  idpSloUrl      String? // Single Logout URL (optional)
  idpCertificate String // X.509 Certificate

  // SP Configuration (자동 생성)
  spAcsUrl   String // Assertion Consumer Service URL
  spEntityId String // Service Provider Entity ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domain])
  @@index([isActive])
}

// System Branding Configuration (시스템 브랜딩 설정 - 단일 고객용)
model SystemBranding {
  id String @id @default("default") // 단일 레코드만 사용

  // Branding Settings
  companyName String  @default("Crinity") // 회사명
  logoUrl     String? // 로고 이미지 URL
  faviconUrl  String? // 파비콘 URL

  // Colors
  primaryColor   String @default("#0f172a") // 기본 색상
  secondaryColor String @default("#3b82f6") // 보조 색상

  // Text Customization
  homepageTitle    String @default("Crinity Helpdesk") // 홈페이지 메인 제목
  homepageSubtitle String @default("민원 티켓을 생성하고 상태를 바로 조회할 수 있습니다.") // 홈페이지 부제목
  adminPanelTitle  String @default("Crinity Admin") // 관리자 패널 제목
  appTitle         String @default("고객 지원 센터") // 앱 제목
  welcomeMessage   String @default("무엇을 도와드릴까요?") // 환영 메시지
  footerText       String @default("© 2024 All rights reserved.") // 푸터 텍스트

  // Footer Contact Information
  footerPhone    String? // 푸터 전화번호
  footerEmail    String? // 푸터 이메일
  footerHomepage String? // 푸터 홈페이지 URL
  footerAddress  String? // 푸터 주소

  // Feature Flags
  showPoweredBy Boolean @default(true) // "Powered by Crinity" 표시 여부
  customCss     String? // 커스텀 CSS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Email Settings (이메일 서버 설정)
model EmailSettings {
  id String @id @default("default")

  // Email Provider
  provider String @default("nodemailer") // nodemailer, ses, resend

  // SMTP Settings (for nodemailer)
  smtpHost     String?
  smtpPort     Int     @default(587)
  smtpSecure   Boolean @default(false)
  smtpUser     String?
  smtpPassword String?

  // Sender Settings
  fromEmail String @default("no-reply@company.com")
  fromName  String @default("Crinity Helpdesk")

  // AWS SES Settings
  sesAccessKey String?
  sesSecretKey String?
  sesRegion    String  @default("ap-northeast-2")

  // Resend API Key
  resendApiKey String?

  // Notification Settings
  notificationsEnabled Boolean @default(true)
  notifyOnNewTicket    Boolean @default(true)
  notifyOnAssign       Boolean @default(true)
  notifyOnComment      Boolean @default(true)
  notifyOnStatusChange Boolean @default(true)
  notificationEmail    String?

  // Test Settings
  testMode Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// LLM Settings (AI 분석 설정)
model LLMSettings {
  id String @id @default("default")

  // Provider Selection
  provider String @default("ollama") // ollama, gemini

  // Ollama Settings
  ollamaUrl   String @default("http://localhost:11434")
  ollamaModel String @default("llama3.2")

  // Gemini Settings
  geminiApiKey String?
  geminiModel  String  @default("gemini-1.5-flash")

  // Analysis Settings
  analysisEnabled Boolean @default(false)
  analysisPrompt  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Team (팀/그룹 관리)
model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      TeamMember[]
  tickets      Ticket[]
  defaultTypes RequestType[] // RequestType에서 defaultTeam으로 참조

  @@index([isActive])
}

model TeamMember {
  teamId    String
  agentId   String
  isLeader  Boolean  @default(false)
  createdAt DateTime @default(now())

  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@id([teamId, agentId])
  @@index([agentId])
}

// Request Type (문의 유형 관리)
model RequestType {
  id                String             @id @default(cuid())
  name              String             @unique
  description       String?
  channel           RequestTypeChannel @default(WEB)
  defaultPriority   TicketPriority     @default(MEDIUM)
  defaultTeamId     String?
  categoryId        String?            @unique // Link to Category for agent specialization
  autoAssignEnabled Boolean            @default(true)
  isActive          Boolean            @default(true)
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tickets           Ticket[]
  responseTemplates ResponseTemplate[]
  defaultTeam       Team?              @relation(fields: [defaultTeamId], references: [id], onDelete: SetNull)
  category          Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([sortOrder])
  @@index([categoryId])
}

// Custom Field (커스텀 필드 정의)
model CustomFieldDefinition {
  id          String          @id @default(cuid())
  key         String          @unique
  name        String
  description String?
  fieldType   CustomFieldType
  options     Json? // SELECT/MULTI_SELECT용 옵션 배열
  isRequired  Boolean         @default(false)
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  values CustomFieldValue[]

  @@index([isActive])
  @@index([sortOrder])
}

model CustomFieldValue {
  id        String   @id @default(cuid())
  ticketId  String
  fieldId   String
  value     String // JSON으로 저장된 값
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticket Ticket                @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  field  CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([ticketId, fieldId])
  @@index([ticketId])
  @@index([fieldId])
}

// SLA Policy (SLA 정책)
model SLAPolicy {
  id                 String         @id @default(cuid())
  name               String
  description        String?
  priority           TicketPriority
  firstResponseHours Float // 첫 응답 시간 (시간)
  resolutionHours    Float // 해결 시간 (시간)
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  clocks SLAClock[]

  @@unique([priority, isActive])
  @@index([isActive])
}

model SLAClock {
  id                 String         @id @default(cuid())
  ticketId           String
  policyId           String
  target             SLATarget
  status             SLAClockStatus @default(RUNNING)
  startedAt          DateTime       @default(now())
  pausedAt           DateTime?
  totalPausedMinutes Int            @default(0)
  deadlineAt         DateTime
  breachedAt         DateTime?
  warningSentAt      DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  ticket Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  policy SLAPolicy @relation(fields: [policyId], references: [id], onDelete: Restrict)

  @@index([ticketId])
  @@index([policyId])
  @@index([status])
  @@index([deadlineAt])
}

// Business Calendar (업무 시간/휴일 관리)
model BusinessCalendar {
  id            String   @id @default(cuid())
  name          String
  timezone      String   @default("Asia/Seoul")
  workStartHour Int      @default(9) // 24시간 형식
  workEndHour   Int      @default(18)
  workDays      String?  @default("[1,2,3,4,5]") // 0=일, 1=월, ..., 6=토
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  holidays Holiday[]

  @@index([isActive])
}

model Holiday {
  id          String   @id @default(cuid())
  calendarId  String
  name        String
  date        DateTime
  isRecurring Boolean  @default(false) // 매년 반복
  createdAt   DateTime @default(now())

  calendar BusinessCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@index([calendarId])
  @@index([date])
}

// Email Thread Mapping (이메일 스레딩)
model EmailThreadMapping {
  id              String    @id @default(cuid())
  ticketId        String
  messageId       String    @unique // 이메일 Message-ID 헤더
  inReplyTo       String? // In-Reply-To 헤더
  references      String? // References 헤더 배열 (JSON)
  subject         String
  fromAddress     String
  toAddress       String
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?
  isProcessed     Boolean   @default(false)
  processingError String?
  createdAt       DateTime  @default(now())

  @@index([ticketId])
  @@index([messageId])
  @@index([inReplyTo])
  @@index([isProcessed])
  @@index([receivedAt])
}

// Git Event (Git 웹훅 이벤트)
model GitEvent {
  id            String       @id @default(cuid())
  ticketId      String
  provider      GitProvider
  eventType     GitEventType
  repoFullName  String
  ref           String? // 브랜치/태그명
  commitSha     String?
  commitMessage String?
  authorName    String?
  authorEmail   String?
  prNumber      Int?
  prTitle       String?
  prUrl         String?
  occurredAt    DateTime // 실제 Git 이벤트 발생 시간
  createdAt     DateTime     @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([provider])
  @@index([eventType])
  @@index([occurredAt])
}

// Saved Filter (저장된 필터/뷰)
model SavedFilter {
  id           String   @id @default(cuid())
  name         String
  description  String?
  filterConfig Json // 필터 설정 JSON
  sortConfig   Json? // 정렬 설정 JSON
  isDefault    Boolean  @default(false)
  isShared     Boolean  @default(false) // 팀원과 공유
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy Agent @relation("FilterCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([isShared])
}

// Git Operation Queue (Git 연동 실패 시 재시도)
model GitOperationQueue {
  id           String      @id @default(cuid())
  operation    String // CREATE_ISSUE, LINK_ISSUE, etc.
  provider     GitProvider
  payload      Json // 요청 데이터
  status       String      @default("PENDING") // PENDING, PROCESSING, SUCCESS, FAILED
  retryCount   Int         @default(0)
  maxRetries   Int         @default(3)
  errorCode    String? // TIMEOUT, AUTH_FAILED, RATE_LIMIT, etc.
  errorMessage String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  processedAt  DateTime?

  @@index([status])
  @@index([retryCount])
  @@index([createdAt])
}

// Ticket Merge (티켓 병합)
model TicketMerge {
  id             String   @id @default(cuid())
  sourceTicketId String
  targetTicketId String
  mergedAt       DateTime @default(now())
  mergedBy       String

  sourceTicket Ticket @relation("TicketSource", fields: [sourceTicketId], references: [id], onDelete: Cascade)
  targetTicket Ticket @relation("TicketTarget", fields: [targetTicketId], references: [id], onDelete: Cascade)

  @@index([sourceTicketId])
  @@index([targetTicketId])
  @@index([mergedAt])
}

// Time Entry (시간 추적)
model TimeEntry {
  id        String    @id @default(cuid())
  ticketId  String
  agentId   String
  startTime DateTime  @default(now())
  endTime   DateTime?
  duration  Int?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  agent  Agent  @relation("TimeEntries", fields: [agentId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([agentId])
  @@index([startTime])
}

// Automation Rule (자동화 규칙)
model AutomationRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  conditions  Json // { status, priority, categoryId, assigneeId, teamId, ... }
  actions     Json // { setStatus, setAssignee, addTag, sendNotification, ... }
  isActive    Boolean  @default(true)
  priority    Int      @default(0) // 우선순위 (높을수록 먼저 실행)
  triggerOn   String?  @default("TICKET_CREATED") // TICKET_CREATED, TICKET_UPDATED, TICKET_COMMENT, TICKET_ASSIGNED
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy Agent @relation("AutomationCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([priority])
  @@index([triggerOn])
}

// Customer Satisfaction Survey (CSAT) (고객 만족도 조사)
model CustomerSatisfaction {
  id            String   @id @default(cuid())
  ticketId      String   @unique
  ticketNumber  String
  customerId    String?
  customerEmail String
  rating        Int // 1~5점
  comment       String?
  submittedAt   DateTime @default(now())

  ticket Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([customerId])
}

model KnowledgeCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles KnowledgeArticle[]

  @@index([sortOrder, isActive])
}

model KnowledgeArticle {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  content        String
  excerpt        String?
  categoryId     String
  authorId       String
  lastEditedById String?
  viewCount      Int       @default(0)
  isPublished    Boolean   @default(false)
  isPublic       Boolean   @default(false)
  publishedAt    DateTime?
  tags           Json?     @default("[]")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  category     KnowledgeCategory          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  author       Agent                      @relation("KnowledgeArticleAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  lastEditedBy Agent?                     @relation("KnowledgeArticleLastEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  feedback     KnowledgeArticleFeedback[]

  @@index([categoryId])
  @@index([authorId])
  @@index([lastEditedById])
  @@index([isPublished, isPublic])
  @@index([publishedAt])
}

model KnowledgeArticleFeedback {
  id           String   @id @default(cuid())
  articleId    String
  sessionToken String
  wasHelpful   Boolean
  comment      String?
  createdAt    DateTime @default(now())

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, sessionToken])
  @@index([articleId, wasHelpful])
}

// Ticket Presence (상담원 티켓 조회 상태)
model TicketPresence {
  id         String   @id @default(cuid())
  ticketId   String
  agentId    String
  lastSeenAt DateTime @updatedAt
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  agent  Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([ticketId, agentId])
  @@index([ticketId, lastSeenAt])
  @@index([agentId, lastSeenAt])
}

// Ticket Comment Lock (댓글 동시 편집 방지)
model TicketCommentLock {
  id        String   @id @default(cuid())
  ticketId  String   @unique
  agentId   String
  acquiredAt DateTime @default(now())
  expiresAt DateTime

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  agent  Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, expiresAt])
  @@index([expiresAt])
}
