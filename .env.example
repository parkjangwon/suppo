# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/crinity
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=crinity

# Auth
AUTH_SECRET=your-secret-min-32-characters-long
AUTH_URL=http://localhost:3000

# OAuth Providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# SAML SSO (BoxyHQ)
AUTH_BOXYHQ_SAML_ID=
AUTH_BOXYHQ_SAML_SECRET=
AUTH_BOXYHQ_SAML_ISSUER=https://saml.boxyhq.com

# Email
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Storage
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# App storage settings
AWS_S3_BUCKET_NAME=
AWS_REGION=
UPLOAD_DIR=./uploads

# Security
TICKET_ACCESS_SECRET=
GIT_TOKEN_ENCRYPTION_KEY=

# Initial Admin Account (최초 관리자 계정)
INITIAL_ADMIN_EMAIL=admin@crinity.io
INITIAL_ADMIN_PASSWORD=admin1234
