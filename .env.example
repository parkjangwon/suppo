# =============================================================================
# 필수 환경 변수 (이 값들은 .env 파일에 반드시 설정해야 합니다)
# =============================================================================

# Database (필수) - PostgreSQL 연결 문자열
DATABASE_URL=postgresql://suppo:suppo_dev@localhost:5432/suppo

# Local/Docker PostgreSQL password
# - 로컬 install.sh 기본값과 docker compose 기본값입니다.
# - 운영 배포에서는 반드시 변경하세요.
POSTGRES_PASSWORD=suppo_dev

# Auth (필수) - 루트 도구/테스트용 기본값, 앱 개발은 apps/*/.env.local 사용
AUTH_SECRET=your-secret-min-32-characters-long
AUTH_URL=http://localhost:3000

# Public/Admin absolute base URLs
# - 개발 기본값: public=http://localhost:3000, admin=http://localhost:3001
# - 운영 배포 시: 리버스 프록시 / 도메인 / 포트에 맞는 외부 접속 URL을 넣으세요.
PUBLIC_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:3001

# 앱 기본 URL (이메일 링크 생성 등에 사용, PUBLIC_URL과 동일하게 설정)
APP_BASE_URL=http://localhost:3000

# 파일 업로드 디렉토리
# - 상대 경로는 프로젝트 루트 기준입니다.
# - public/admin 앱이 같은 경로를 참조해야 첨부파일이 양쪽에서 보입니다.
UPLOAD_DIR=uploads

# Email Message-ID 도메인 (선택)
EMAIL_DOMAIN=localhost

# Ticket Access (필수) - 티켓 접근 토큰 서명용 (최소 32자 권장)
TICKET_ACCESS_SECRET=your-ticket-access-secret-min-32-characters

# Git Integration (필수) - Git 토큰 암호화용 (최소 32자 권장)
GIT_TOKEN_ENCRYPTION_KEY=your-32-byte-encryption-key

# Initial Admin Account (필수) - 최초 관리자 계정
INITIAL_ADMIN_EMAIL=admin@suppo.io
INITIAL_ADMIN_PASSWORD=admin1234

# =============================================================================
# 선택적 환경 변수 (기능 활성화 시 설정)
# =============================================================================

# Redis (선택) - 실시간 presence/lock 기능 활성화 시 필요
# REDIS_URL=redis://localhost:6379

# Sentry (선택) - 오류 모니터링
# SENTRY_DSN=https://xxxx@sentry.io/yyyy

# 이메일 발송 (선택 중 택일)
# --- Resend ---
# RESEND_API_KEY=re_xxxx
# --- SMTP ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com
# --- AWS SES ---
# AWS_SES_REGION=ap-northeast-2
# AWS_SES_ACCESS_KEY_ID=AKIA...
# AWS_SES_SECRET_ACCESS_KEY=...
# AWS_SES_FROM=noreply@example.com

# Cloudflare Turnstile CAPTCHA (선택) - 포털 스팸 방지
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
# TURNSTILE_SECRET_KEY=0x...

# 보고서 파일 저장 경로 (선택, 기본값: ./reports)
# REPORTS_STORAGE_PATH=/var/data/suppo/reports

# 내부 자동화 토큰 (선택) - cron 작업 인증용
INTERNAL_AUTOMATION_DISPATCH_TOKEN=your-secret-token
INTERNAL_EMAIL_DISPATCH_TOKEN=your-secret-token

# SSO 공급자 (선택 중 택일)
# --- GitHub OAuth ---
# AUTH_GITHUB_ID=your-github-app-id
# AUTH_GITHUB_SECRET=your-github-app-secret
# --- Google OAuth ---
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret
# --- SAML (BoxyHQ) ---
# AUTH_BOXYHQ_SAML_ISSUER=https://admin.example.com
# AUTH_BOXYHQ_SAML_CLIENT_ID=dummy
# AUTH_BOXYHQ_SAML_CLIENT_SECRET=dummy

# =============================================================================
# 참고: 그 외 모든 설정은 웹 관리 콘솔에서 관리됩니다
# =============================================================================
# 앱별 로컬 개발 환경 파일
# - apps/public/.env.local
# - apps/admin/.env.local
#
# 예시
# apps/public/.env.local
#   DATABASE_URL=postgresql://suppo:suppo_dev@localhost:5432/suppo
#   TICKET_ACCESS_SECRET=local-dev-ticket-secret
#   AUTH_URL=http://localhost:3000
#   PUBLIC_URL=http://localhost:3000
#
# apps/admin/.env.local
#   DATABASE_URL=postgresql://suppo:suppo_dev@localhost:5432/suppo
#   AUTH_SECRET=local-dev-secret-32-chars-minimum
#   TICKET_ACCESS_SECRET=local-dev-ticket-secret
#   GIT_TOKEN_ENCRYPTION_KEY=local-dev-encryption-key-32bytexx
#   INITIAL_ADMIN_EMAIL=admin@suppo.io
#   INITIAL_ADMIN_PASSWORD=admin1234
#   AUTH_URL=http://localhost:3001
#   ADMIN_BASE_URL=http://localhost:3001
#
# - 이메일 설정 (SMTP/SES/Resend): /admin/settings/email
# - AI/LLM 설정 (Ollama/Gemini): /admin/settings/llm
# - 브랜딩 설정 (로고/색상): /admin/settings/branding
# - SAML SSO 설정: /admin/settings/saml
# - 문의 유형 관리: /admin/settings/request-types
# - Git 연동 설정: /admin/settings/git
# =============================================================================
# 운영 예시
#   PUBLIC_URL=https://helpdesk.example.com
#   ADMIN_BASE_URL=https://admin.example.com
#   EMAIL_DOMAIN=example.com
#
# Docker / reverse proxy 환경에서도 반드시 "외부에서 접속하는 최종 URL"을 넣으세요.
# 내부 컨테이너 포트(예: :3000, :3001)를 넣지 말고,
# 프록시 뒤의 실제 공개 URL을 넣어야 메일 링크/SAML/메타데이터가 올바르게 생성됩니다.
# =============================================================================
